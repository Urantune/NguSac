document.addEventListener("DOMContentLoaded",function(){document.querySelectorAll(".mega-menu").forEach(menu=>{const details=menu.closest("details")||menu,summary=details.querySelector("summary"),isDesktop=window.innerWidth>=990;if(!details)return;const open=()=>{isDesktop&&(details.setAttribute("open",""),summary.setAttribute("aria-expanded",!0))},close=()=>{isDesktop&&(details.removeAttribute("open"),summary.setAttribute("aria-expanded",!1))};menu.addEventListener("mouseenter",()=>{open()}),menu.addEventListener("focusin",()=>{open()}),menu.addEventListener("mouseleave",()=>{close()}),summary&&summary.addEventListener("click",e=>{isDesktop&&e.preventDefault()})})});
